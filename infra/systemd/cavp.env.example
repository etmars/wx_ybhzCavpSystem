# 复制到服务器后改名，例如：
#   /home/wx_ybhzCavpSystem/cavp.env
# 或 /etc/cavp/cavp.env（与 unit 里 EnvironmentFile= 一致）

# 本机监听地址（默认 127.0.0.1，仅本机 Nginx 反代；若需局域网直连可改为 0.0.0.0）
SERVER_ADDRESS=127.0.0.1

# 数据目录（地图缓存 data/maps、config.db）
DATA_DIR=/home/wx_ybhzCavpSystem/data

# 可选：对接 parkinglot / 标定服（application.yml 已有默认值，仅需覆盖时再写）
# PARKING_API_BASE_URL=http://127.0.0.1:3000
# CALIB_API_BASE_URL=http://127.0.0.1:18181
