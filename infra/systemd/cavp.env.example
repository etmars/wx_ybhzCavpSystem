# /etc/cavp/cavp.env
# 复制：sudo cp infra/systemd/cavp.env.example /etc/cavp/cavp.env && sudo chmod 600 /etc/cavp/cavp.env

# 生产 HTTPS 证书（PKCS12，由 certbot + openssl 生成，见 README）
CERT_PATH=/opt/cavp/cert/keystore.p12
CERT_PWD=changeit
CERT_ALIAS=cavp

# 数据目录（地图缓存 data/maps、config.db）；相对 WorkingDirectory 时也可写 ./data
DATA_DIR=/opt/cavp/wx_ybhzCavpSystem/data

# 可选：对接 parkinglot / 标定服（application.yml 已有默认值，仅需覆盖时再写）
# PARKING_API_BASE_URL=http://127.0.0.1:3000
# CALIB_API_BASE_URL=http://127.0.0.1:18181
